{
  "name": "sitelease/silverstripe-aspect-ratio-validator",
  "description": "Validates the aspect ratio of an image during upload",
  "type": "silverstripe-vendormodule",
  "keywords": [
        "sitelease",
        "silverstripe",
        "5",
        "image",
        "ratio",
        "validation"
  ],
  "authors": [
    {
      "name": "James Heathcote",
      "email": "james.h@biffbangpow.com",
      "role": "Original Developer"
    },
    {
      "name": "Benjamin Blake",
      "homepage": "https://sitelease.ca",
      "role": "Developer"
    }
  ],
  "require": {
    "silverstripe/vendor-plugin": "^2.0",
    "silverstripe/cms": "^5"
  },
  "minimum-stability": "dev",
  "autoload": {
    "psr-4": {
      "Sitelease\\AspectRatioValidator\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "silverstripe/vendor-plugin": true
    }
  }
}
